<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.5/jszip.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/epubjs/dist/epub.min.js"></script>
  <style>
    body { margin: 0; padding: 0; width: 100vw; height: 100vh; background-color: transparent; }
    #viewer { width: 100%; height: 100%; }
  </style>
</head>
<body>
  <div id="viewer"></div>

  <script>
    window.currentSettings = null;
    window.rendition = null;

    function applySettings() {
      if (!window.currentSettings || !window.rendition) return;
      const data = window.currentSettings;
      
      try {
          const textColor = data.colors ? data.colors.text : '#11181C';
          const bgColor = data.colors ? data.colors.background : '#F2F4F7';

          document.body.style.backgroundColor = bgColor;

          let fontStack = '-apple-system, system-ui, sans-serif';
          if (data.currentFont === 'Serif') {
            fontStack = 'Georgia, "Times New Roman", serif';
          } else if (data.currentFont === 'Monospace') {
            fontStack = 'ui-monospace, "Courier New", monospace';
          }

          window.rendition.themes.register("dynamicTheme", {
            "body": {
              "background": `${bgColor} !important`,
              "background-color": `${bgColor} !important`
            },
            "p, span, div, h1, h2, h3, h4, h5, h6, li, blockquote, a": {
              "color": `${textColor} !important`,
              "font-family": `${fontStack} !important`,
              "background-color": "transparent !important"
            }
          });
          
          window.rendition.themes.select("dynamicTheme");

      } catch(e) {
          console.error('Theme Error:', e);
      }
    }

    function handleNativeMessage(event) {
      try {
        const msg = event.data;
        if (typeof msg !== 'string') return;

        if (msg.startsWith("SETTINGS:")) {
          window.currentSettings = JSON.parse(msg.substring(9));
          applySettings();
        } 
        else if (msg.startsWith("BOOK:")) {
          const base64 = msg.substring(5);
          
          window.book = ePub(base64, { encoding: "base64" });
          
          window.rendition = window.book.renderTo("viewer", {
            width: "100%",
            height: "100%",
            manager: "continuous",
            flow: "scrolled",
          });
          
          window.rendition.display().then(function() {
            applySettings();
          }).catch(function(err) {
            console.error('Display Error:', err);
          });
        }
      } catch (err) {
        console.error('Listener Error:', err);
      }
    }

    window.addEventListener("message", handleNativeMessage);
    document.addEventListener("message", handleNativeMessage);

    function notifyReady() {
      if (window.ReactNativeWebView) {
        window.ReactNativeWebView.postMessage("READY");
      } else {
        setTimeout(notifyReady, 50);
      }
    }
    notifyReady();
  </script>
</body>
</html>
</file>

