      <View style={styles.info}>
        <Text style={[styles.title, { color: theme.text }]} numberOfLines={3}>
          {title}
        </Text>
        {author && (
          <Text
            style={[styles.author, { color: theme.textSecondary }]}
            numberOfLines={1}
          >
            {author}
          </Text>
        )}
      </View>
    </TouchableOpacity>
  );
}

